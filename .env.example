# ==============================================================================
# NEXUS Environment Configuration Template
# COPY THIS FILE TO .env AND REPLACE ALL 'CHANGE_ME' VALUES WITH SECURE SECRETS
# ==============================================================================

# --- Global Infrastructure ---
# Internal Docker networking uses service names (postgres, questdb, redis)
QUESTDB_HOST=questdb
QUESTDB_PG_PORT=8812
QUESTDB_ILP_PORT=9009
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest

REDIS_URL=redis://redis:6379/0

POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=nexus

# --- Authentication Service ---
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
SECRET_KEY=CHANGE_ME_TO_A_256_BIT_SECURE_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- UI (React/Vite) ---
# Note: VITE_ prefixed variables are injected at build time.
# These should point to the public-facing URL of your Nginx gateway.
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws

# --- External API Keys ---
# Add your Alpaca API credentials here for real-time market data ingestion
ALPACA_API_KEY=CHANGE_ME_OPTIONAL
ALPACA_SECRET_KEY=CHANGE_ME_OPTIONAL

# --- General ---
RUST_LOG=info
CORS_ORIGINS=http://localhost:80
